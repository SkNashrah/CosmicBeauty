<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CosmicBeauty.Views.SettingsPage"
             xmlns:vm="clr-namespace:CosmicBeauty.ViewModels"
             x:DataType="vm:SettingsViewModel"
             BackgroundColor="{AppThemeBinding Light={StaticResource CosmicBackground}, Dark={StaticResource CosmicBackgroundDark}}"
             Title="Settings">

    <VerticalStackLayout Padding="20" Spacing="15">
        <!-- Dark Mode Toggle -->
        <HorizontalStackLayout Spacing="10">
            <Label Text="Dark Mode" 
                   Style="{StaticResource CosmicPrimaryText}"
                   VerticalOptions="Center"
                   FontSize="16"/>
            <Switch x:Name="DarkModeSwitch"
                    Style="{StaticResource CosmicSwitch}"
                    IsToggled="{Binding DarkMode}"
                    HorizontalOptions="End"
                    VerticalOptions="Center"/>
        </HorizontalStackLayout>

        <!-- Notifications Toggle -->
        <HorizontalStackLayout Spacing="10">
            <Label Text="Enable Notifications" 
                   VerticalOptions="Center"
                   Style="{StaticResource CosmicPrimaryText}"
                   FontSize="16"/>
            <Switch x:Name="NotificationsSwitch"
                    Style="{StaticResource CosmicSwitch}"
                    IsToggled="{Binding EnableNotifications}"
                    HorizontalOptions="End"
                    VerticalOptions="Center"/>
        </HorizontalStackLayout>

        <Label Text="Volume Level"
               Style="{StaticResource CosmicPrimaryText}"
               FontSize="16"
               Margin="0,20,0,0"/>

        <Slider x:Name="VolumeSlider"
                Minimum="0"
                Maximum="100"
                Value="{Binding VolumeLevel}"
                MinimumTrackColor="{AppThemeBinding Light={StaticResource CosmicPrimary},Dark={StaticResource CosmicPrimaryDark}}"
                MaximumTrackColor="{AppThemeBinding Light={ StaticResource CosmicSecondary}, Dark={StaticResource CosmicSecondaryDark}}"/>

        <ProgressBar x:Name="VolumeProgressBar"
                     Progress="{Binding VolumeProgress}"
                     ProgressColor="{AppThemeBinding Light={StaticResource CosmicPrimary},Dark={StaticResource CosmicPrimaryDark}}"
                     BackgroundColor="{AppThemeBinding Light={ StaticResource CosmicSecondary}, Dark={StaticResource CosmicSecondaryDark}}"
                     HeightRequest="30"
                     Margin="0,5"/>

        <Label Text="{Binding VolumeLevel, StringFormat='{0:F0}%'}"
               Style="{StaticResource CosmicText}"
               FontAttributes="Bold"
               HorizontalOptions="Center"/>

        <!-- Save Button -->
        <Button x:Name="SaveButton"
                Text="Save Settings"
                Style="{StaticResource CosmicButton}"
                Command="{Binding SaveCommand}"
                IsEnabled="{Binding HasChanges}"
                Margin="0,20,0,0"
                HeightRequest="50"/>
    </VerticalStackLayout>
</ContentPage>